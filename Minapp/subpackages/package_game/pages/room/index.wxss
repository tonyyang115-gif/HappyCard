/* Flex Layout Fix for 100vh scrolling */
page {
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
}

.room-container {
    background: linear-gradient(180deg, #dce9ff 0%, #f5f7fa 25%, #f5f7fa 100%);
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding-bottom: 0px; /* Reset */
}

.header-bg {
    background: transparent;
    padding: 20px 24px;
    padding-top: calc(90px + env(safe-area-inset-top)); 
    flex-shrink: 0; /* Keep header fixed */
}

/* ... skipped logo/profile ... */

.tip-pill {
    /* Removed background for cleaner look as per plan */
    background-color: transparent; 
    padding: 4px 0; /* Removing horizontal padding if no bg */
    font-size: 11px;
    color: #9ca3af;
    display: flex;
    align-items: center;
    gap: 4px;
    font-weight: 500;
}
.info-icon { font-size: 14px; }

/* ... skipped invite-square-btn ... */

.player-item {
    background-color: white;
    border-radius: 16px;
    padding: 20px;
    display: flex;
    align-items: center;
    margin-bottom: 16px; /* Increased spacing */
    box-shadow: 0 4px 20px rgba(0,0,0,0.03); /* Softer shadow */
    border: 1px solid white; /* Subtle border instead of gray */
    transition: all 0.2s;
}

.tag-me {
    background-color: #4b88ff;
    color: white;
    font-size: 10px;
    padding: 0;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px; /* Fixed size */
    height: 18px;
    line-height: 18px;
    text-align: center;
    margin-left: 4px;
}

/* ... (skipped other tags) ... */

.score-card {
    /* Vivid Blue Gradient */
    background: linear-gradient(135deg, #4285f4, #2563eb); 
    border-radius: 16px;
    padding: 20px;
    color: white;
    /*box-shadow: 0 4px 25px -5px rgba(37, 99, 235, 0.4)*/
    box-shadow: 0 4px 15px rgba(37, 99, 235, 0.2);
    position: relative;
    overflow: hidden;
    min-height: 160px;
    margin-top: 32px; /* Increased spacing */
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.refresh-btn {
    width: 44px; height: 44px;
    border-radius: 50%;
    background-color: rgba(255,255,255,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
}
.refresh-icon {
    font-size: 20px;
    color: white;
    transform: rotate(45deg);
}

/* Abstract Background on Card */
.card-bg-shape {
    position: absolute;
    top: -50px;
    right: -80px;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0) 70%);
    border-radius: 50%;
    pointer-events: none;
}

.trophy-icon-text {
    position: absolute;
    top: 50%;
    right: -20px; /* Shifted right */
    transform: translateY(-50%) rotate(-10deg); /* Slight rotation */
    font-size: 140px; /* Larger */
    opacity: 0.12;
    pointer-events: none;
    line-height: 1;
}

.text-6xl { font-size: 3.75rem; line-height: 1; }
.text-3xl { font-size: 28px; line-height: 1.2; }
.text-2xl { font-size: 22px; line-height: 1.2; } /* Smaller Name */

.logo-text {
    display: flex;
    align-items: center;
    color: #111827;
    font-weight: 800; /* Extra bold */
    font-size: 20px;
    gap: 6px;
}
.logo-icon-text {
    font-size: 24px;
    color: #3b82f6;
    margin-top: -2px;
}

.profile-link {
    color: #3b82f6;
    border: 1.5px solid #3b82f6; /* Slightly thicker border */
    padding: 6px 20px; /* Wider pill */
    border-radius: 99px;
    font-size: 14px;
    background-color: rgba(255,255,255,0.8);
    font-weight: 500;
    letter-spacing: 0.5px;
    display: inline-block; /* Prevent inline wrapping issues */
    white-space: nowrap; /* Prevent wrapping */
    line-height: normal;
}

.tip-pill {
    background-color: white; /* or very light gray */
    padding: 4px 10px;
    border-radius: 99px;
    font-size: 10px;
    color: #9ca3af;
    display: flex;
    align-items: center;
    gap: 4px;
    /* border: 1px solid #f3f4f6; Optional */
}
.info-icon { font-size: 12px; }

/* 房间信息核心数值显式色彩定义 (修复设置不生效问题) */
.room-id-value, .base-score-value {
    color: #2563eb !important; /* 主题蓝色 */
    font-weight: bold;
}

.player-count-value {
    color: #9ca3af !important; /* 标签一致的浅灰色 */
    font-weight: bold;
}

/* Room meta row: keep all items in one row without squeezing text */
.room-meta-row {
    width: 100%;
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    justify-content: flex-start;
}

.room-meta-left {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 0;
}

.room-meta-right {
    flex-shrink: 0;
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0;
}

.room-meta-pill {
    white-space: nowrap;
    flex-shrink: 0;
}

.room-meta-readonly {
    margin-left: 2rpx;
}

.room-meta-divider {
    width: 1px;
    height: 22rpx;
    background: rgba(59, 130, 246, 0.18);
    margin: 0 6rpx;
    border-radius: 1px;
    flex-shrink: 0;
    align-self: center;
}

.player-count-pill {
    flex-shrink: 0;
}

/* Room Actions and List */
.invite-share-btn {
    height: 64rpx;
    line-height: 64rpx;
    min-width: 124rpx;
    border-radius: 12rpx;
    border: 1.5px solid #3b82f6;
    background: #eff6ff;
    color: #3b82f6;
    font-size: 24rpx;
    font-weight: 700;
    padding: 0 20rpx;
    margin: 0;
    flex-shrink: 0;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}
.invite-share-btn::after {
    border: none;
}

.player-item {
    background-color: #ffffff; /* White for better contrast */
    border-radius: 20px;
    padding: 16px 30px 16px 20px;
    display: flex;
    align-items: center;
    margin-bottom: 12px;
    border: 1px solid #dbeafe; /* Visible light blue border */
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.08); /* Stronger blue-ish shadow */
}
.player-item.is-me {
    background-color: #f0f7ff; /* Slightly deeper blue for self */
    border-color: #dbeafe;
}

/* 已退出玩家的样式 */
.player-item.player-left {
    background-color: #f3f4f6; /* 灰色背景 */
    border-color: #e5e7eb;
    opacity: 0.7;
}

.player-item.player-left .player-name {
    color: #9ca3af; /* 灰色文字 */
}

.player-item.player-left .score-number {
    color: #9ca3af; /* 灰色积分 */
}

/* 已退出标签样式 */
.left-tag-pill {
    position: absolute;
    bottom: -4px;
    left: 50%;
    transform: translateX(-50%);
    background-color: #ef4444;
    color: white;
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 8px;
    font-weight: bold;
    white-space: nowrap;
}

/* 已退出玩家的头像样式 */
.avatar-left {
    filter: grayscale(100%); /* 灰度头像 */
}

.rank-area {
    width: 40px; /* Spacing for rank */
    display: flex;
    justify-content: center;
    margin-right: 8px;
}
.rank-medal-icon { font-size: 24px; }
.rank-badge {
    color: #9ca3af;
    font-weight: bold;
    font-size: 16px;
}

.avatar-wrapper {
    position: relative;
    margin-right: 4px; /* Space between avatar and info */
}
/* Ensure avatar component handles border class correctly or wrap it */
/* Assuming avatar component accepts className or we stick on wrapper */
.player-avatar-border {
    border: 2px solid #fbbf24; /* Amber-400 */
    border-radius: 12px;
    box-sizing: border-box;
}

.host-tag-pill {
    position: absolute;
    bottom: -4px;
    left: 50%;
    transform: translateX(-50%);
    background-color: #111827; /* Gray-900 */
    color: white;
    font-size: 9px;
    padding: 2px 6px;
    border-radius: 10px;
    white-space: nowrap;
    z-index: 5;
    line-height: 1;
}

.player-name {
    font-size: 16px;
    font-weight: bold;
    color: #3b82f6; /* Blue-500 */
}

.tag-me-circle {
    background-color: #3b82f6;
    color: white;
    width: 20px; height: 20px;
    border-radius: 50%;
    font-size: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
}

.main-content {
    flex: 1; /* Take remaining space */
    width: 100%;
    padding: 0 32rpx;
    box-sizing: border-box;
    margin-top: -30rpx;
    position: relative;
    z-index: 20;
    display: flex;
    flex-direction: column;
    overflow: hidden; /* Prevent spill */
}

.main-content.with-action-bar {
    padding-bottom: calc(260rpx + env(safe-area-inset-bottom)); /* tighter action bar + tabbar */
}

.main-content.without-action-bar {
    padding-bottom: calc(130rpx + env(safe-area-inset-bottom)); /* tabbar only */
}

.tag-first-pill {
    background-color: #fef9c3; /* Yellow-100 */
    color: #b45309; /* Yellow-700 */
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 6px;
    font-weight: bold;
    margin-top: 2px;
}

.player-list {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    height: 100%;
}

.player-scroll-view {
    height: 100%; /* Fill container */
    width: 100%;
    margin-top: 20rpx;
    display: flex;
    flex-direction: column;
}

.score-number {
    font-size: 24px;
    font-weight: bold;
    color: #cbd5e1; /* Light Slate - placeholder color if 0? Screenshot shows grey 0 */
}
/* Active score color override if needed */
.player-item .score-number { color: #d1d5db; } /* Gray-300 default */

.score-unit {
    font-size: 10px;
