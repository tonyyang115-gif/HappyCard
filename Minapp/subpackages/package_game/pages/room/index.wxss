/* Modal Styles */
.modal-overlay {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: rgba(0,0,0,0.4);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(2px);
}
.modal-content {
    background-color: white;
    width: 85%;
    max-width: 340px;
    border-radius: 20px;
    padding: 24px;
    animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}
@keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    font-size: 18px;
}
.close-btn { 
    font-size: 24px; 
    color: #9ca3af; 
    padding: 4px;
    line-height: .8;
}

.mode-tab {
    flex: 1;
    text-align: center;
    padding: 8px;
    font-size: 14px;
    border-radius: 6px;
    color: #6b7280;
}
.mode-tab.active {
    background-color: white;
    color: #111827;
    font-weight: bold;
    box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05);
}

.section-title {
    font-size: 12px;
    font-weight: bold;
    color: #6b7280;
    margin-bottom: 8px;
}

.avatar-scroll {
    white-space: nowrap;
    width: 100%;
}
.avatar-select-item {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    margin-right: 12px;
    opacity: 0.5;
    transform: scale(0.9);
    transition: all 0.2s;
}
.avatar-select-item.selected-win {
    opacity: 1;
    transform: scale(1);
}
.avatar-select-item.selected-win avatar {
    border: 2px solid #fa9d3b;
    border-radius: 50%;
}
.avatar-select-item.selected-lose {
    opacity: 1;
    transform: scale(1);
}
.avatar-select-item.selected-lose avatar {
    border: 2px solid #ef4444;
    border-radius: 50%;
}

.name-xs { font-size: 10px; margin-top: 4px; overflow: hidden; max-width: 40px; text-overflow: ellipsis; }

.input-big {
