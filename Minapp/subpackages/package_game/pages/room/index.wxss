}

/* Action Sheet Styles */
.action-sheet-overlay {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: rgba(0,0,0,0.5);
    z-index: 200;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    animation: fadeIn 0.2s ease-out;
}

.action-sheet-panel {
    background-color: #f8f8f8;
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    overflow: hidden;
    animation: slideUpSheet 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

/* Base Score Sheet */
.base-score-sheet {
    background-color: #f6f7f9;
    border-top-left-radius: 20px;
    border-top-right-radius: 20px;
}

.base-score-header {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 56px;
    background-color: #ffffff;
    border-bottom: 1px solid #f3f4f6;
}

.base-score-close {
    position: absolute;
    left: 16px;
    font-size: 24px;
    padding: 8px;
    color: #1f2937;
}

.base-score-title {
    font-size: 16px;
    font-weight: 700;
    color: #111827;
}

.base-score-body {
    padding: 20px 16px 12px;
    background-color: #f6f7f9;
}

.base-score-desc {
    display: block;
    font-size: 13px;
    line-height: 20px;
    color: #6b7280;
    margin-bottom: 14px;
}

.base-score-input-row {
    background-color: #ffffff;
    border-radius: 12px;
    border: 1px solid #e5e7eb;
    height: 52px;
    padding: 0 14px;
    display: flex;
    align-items: center;
}

.base-score-input-label {
    font-size: 14px;
    color: #6b7280;
    font-weight: 500;
}

.base-score-input {
    flex: 1;
    text-align: right;
    font-size: 24px;
    font-weight: 700;
    color: #111827;
    height: 52px;
    padding: 0 6px;
}

.base-score-input-unit {
    font-size: 14px;
    color: #6b7280;
    font-weight: 500;
}

.base-score-hint {
    display: block;
    margin-top: 10px;
    font-size: 12px;
    color: #9ca3af;
}

.base-score-footer {
    display: flex;
    gap: 12px;
    padding: 0 16px 16px;
    background-color: #f6f7f9;
}

.base-score-btn {
    flex: 1;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 600;
}

.base-score-btn-secondary {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    color: #374151;
}

.base-score-btn-primary {
    background-color: #3b82f6;
    color: #ffffff;
}

.action-sheet-btn {
    background-color: white;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 17px;
    font-weight: 500;
    color: #000000;
}
.action-sheet-btn:active {
    background-color: #f2f2f2;
}

.text-danger {
    color: #ef4444; /* Red */
    border-bottom: 1px solid #f3f4f6; /* Subtle separator if needed internally */
}

.action-sheet-divider {
    height: 8px;
    background-color: #f1f2f4; /* Light gray gap */
}

/* Handle safe area */
.safe-area-spacer {
    height: constant(safe-area-inset-bottom); /* iOS 11.0 */
    height: env(safe-area-inset-bottom); /* iOS 11.2+ */
    background-color: white; 
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}
@keyframes slideUpSheet {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
}

/* Settlement Modal Styles */
.settle-modal-content {
    background-color: #f9fafb; /* Light bg */
    padding: 24px;
    width: 90%;
}

.settle-hero-card {
    /* Deeper, richer blue gradient */
    background: linear-gradient(135deg, #60a5fa, #2563eb);
    border-radius: 20px; /* Slightly tighter radius */
    padding: 12px; /* Further Reduced Padding for compactness */
    display: flex;
    flex-direction: column;
    align-items: center;
    color: white;
    position: relative;
    box-shadow: 0 8px 20px -6px rgba(37, 99, 235, 0.4);
    margin-bottom: 20px;
    overflow: hidden;
}

/* Subtle gloss effect */
.settle-hero-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 100%;
    background: linear-gradient(180deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 40%);
    pointer-events: none;
}

.hero-crown {
    position: absolute;
    top: 8px; /* Moved up slightly */
    right: 40px; 
    font-size: 32px; /* Smaller Crown */
    transform: rotate(20deg);
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
    animation: floatCrown 3s ease-in-out infinite;
}

@keyframes floatCrown {
    0%, 100% { transform: translateY(0) rotate(20deg); }
    50% { transform: translateY(-4px) rotate(20deg); }
}

.hero-avatar-wrapper {
    margin-bottom: 4px; /* Tighter spacing */
    position: relative;
    z-index: 10;
}

.hero-name {
    font-size: 16px; /* Smaller Name */
    font-weight: 800; 
    margin-bottom: 4px; /* Tighter spacing */
    text-shadow: 0 1px 2px rgba(0,0,0,0.1);
}

.hero-tag {
    background-color: rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(4px);
    color: white;
    font-size: 9px; /* Smaller Tag */
    letter-spacing: 1px;
    padding: 2px 8px; /* Tighter padding */
    border-radius: 99px;
    margin-bottom: 6px; /* Tighter spacing */
    font-weight: 700;
    text-transform: uppercase;
}

.hero-score {
    font-size: 36px; /* Smaller Score */
    font-weight: 900;
    line-height: 1;
    text-shadow: 0 4px 8px rgba(0,0,0,0.15);
    margin-bottom: 2px; /* Tighter spacing */
}



/* Transfer List Refinements */
.transfer-card {
    background-color: white;
    border-radius: 16px;
    padding: 16px;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    border: 1px solid #f3f4f6;
    gap: 16px; /* Explicit gap between sections */
}

/* Enhanced Transfer Card Styles */
.payer-row {
    display: flex;
    align-items: center;
    /* Removed gray bg for cleaner look */
    /* Increased padding to compensate for removed margin */
    /* Right padding is CRITICAL to prevent badge from overlapping the absolute connector spine */
    padding: 8px 32px 8px 0; 
    margin-bottom: 0px; /* Zero gap for seamless connector lines */
    position: relative; /* For absolute connector positioning */
    width: 100%; /* Ensure full width */
    box-sizing: border-box;
}

.payer-amount-badge {
    background-color: #fee2e2; /* Light red/pink bg */
    color: #ef4444;
    font-size: 13px; /* Increased from 11px */
    font-weight: bold;
    padding: 2px 0; /* Horizontal padding removed, width handles it */
    border-radius: 6px;
    margin-left: auto;
    
    /* Fixed Width for Alignment */
    min-width: 90rpx; /* Increased from 80rpx to prevent text wrap */
    text-align: center;
    margin-right: 8px; /* Add spacing from connector */
}

/* Tree Connector Styles */
.connector-tree-container {
    display: none; /* Deprecated in favor of embedded nodes */
}

/* Embedded Fork Node */
.fork-node {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 20px;
}

/* Horizontal Arm (Left to Spine) */
.fork-node::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: #3b82f6;
    transform: translateY(-50%);
}

/* Vertical Spine (Right Edge) */
.fork-node::after {
    content: '';
    position: absolute;
    right: 0;
    width: 2px;
    background-color: #3b82f6;
    /* Default: Full Height (spans entire row) */
    top: 0;
    height: 100%;
}

/* Logic for First Node: Spine starts at center (50%), goes down */
.fork-node.first::after {
    top: 50%;
    height: 50%;
}

/* Logic for Last Node: Spine starts at top, ends at center (50%) */
.fork-node.last::after {
    top: 0;
    height: 50%;
}

/* Logic for Single Node: No Spine, just horizontal thru */
.fork-node.single::after {
    display: none;
}
/* For single node, the horizontal arm (::before) creates the line. 
   The merge-line will meet it at the center. */

.merge-line {
    width: 20px;
    height: 2px;
    background-color: #3b82f6;
    flex-shrink: 0; /* Prevent shrinking */
    /* No margin needed if flex-centered */
}

/* Override height to be dynamic? 
   No, to perfectly align with avatars, we should ideally use the exact same padded container */
.fork-node-spacer {
    padding: 4px 0; /* Matches .payer-row padding */
    height: 32px; /* Matches avatar size xs + extra? avatar xs is usually 24px? */
    /* Let's adjust height based on inspection or trial */
    display: flex;
    align-items: center;
}

.receiver-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #eff6ff 0%, #e0f2fe 100%);
    padding: 12px;
    border-radius: 16px;
    min-width: 130rpx;
    box-shadow: 0 2px 5px rgba(59, 130, 246, 0.05);
    margin-left: auto; /* Push to right */
    margin-right: -16px; /* Pull to edge (counteract parent padding) */
}

/* Connection Status Bar */
.connection-status-bar {
    display: flex;
    align-items: center;
    gap: 8rpx;
    padding: 8rpx 16rpx;
    background: rgba(0, 0, 0, 0.03);
    border-radius: 8rpx;
    margin-bottom: 12rpx;
}

.status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #3b82f6;
}

.status-dot.pulse {
    animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
    0%, 100% {
        opacity: 1;
        transform: scale(1);
    }
    50% {
        opacity: 0.5;
        transform: scale(0.8);
    }
}

/* Read-Only Banner */
.readonly-banner {
    background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
    padding: 12rpx 24rpx;
    border-radius: 8rpx;
    margin-bottom: 16rpx;
    border-left: 4rpx solid #f59e0b;
}

.readonly-text {
    font-size: 12px;
    color: #92400e;
    font-weight: 500;
}
