.page-container {
    height: 100vh;
    background-color: #f9fafb;
    overflow: hidden;
}

.custom-nav {
    position: fixed;
    top: env(safe-area-inset-top); /* 移除多余的 100px */
    left: 0; right: 0;
    height: 44px;
    background-color: white;
    display: flex;
    align-items: center;
    padding-left: 16px;
    z-index: 100;
}

.back-btn {
    display: flex;
    align-items: center;
    height: 100%;
}

.back-icon {
    width: 24px;
    height: 24px;
    margin-right: 4px;
}

.back-text {
    font-size: 18px;
    font-weight: bold;
    color: #111827;
}

.content-area {
    position: absolute;
    top: calc(env(safe-area-inset-top) + 44px); /* 与 nav 衔接 */
    left: 0;
    right: 0;
    bottom: 0;
    padding: 16px;
    box-sizing: border-box;
}

.empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-top: 10px;  /* 极小化，只留 10px 顶部边距 */
    color: #9ca3af;
}

.emoji {
    font-size: 32px;  /* 进一步减小到 32px */
    margin-bottom: 12px;
}

.text {
    font-size: 12px;  /* 进一步减小到 12px */
    color: #6b7280;  /* 更柔和的灰色 */
    margin-bottom: 5px;  /* 进一步减小到 5px */
}

.loading-state {
    text-align: center;
    padding: 40px;
    color: #9ca3af;
}

/* Card Styles */
.history-card {
    background-color: white;
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 12px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.02);
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.time-wrapper {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #6b7280;
    font-size: 15px;
    font-weight: 600;
}

.calendar-icon { font-size: 16px; }

.round-badge {
    background-color: #eff6ff;
    color: #3b82f6;
    font-size: 13px;
    font-weight: bold;
    padding: 4px 12px;
    border-radius: 99px;
}

.players-row {
    display: flex;
    gap: 24px;
    overflow-x: auto;
}

.player-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 60px;
}

.player-name-sm {
    font-size: 12px;
    color: #4b5563;
    margin-top: 4px;
    margin-bottom: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 70px;
    text-align: center;
}

.score-text {
    font-size: 16px;
    font-weight: 900;
    font-family: monospace;
}

.text-orange { color: #f97316; }
.text-green { color: #22c55e; }
.text-gray { color: #9ca3af; }

/* List Footer Styles */
.list-footer {
    padding: 24px 0 40px;
    text-align: center;
    color: #9ca3af;
    font-size: 13px;
}

.footer-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}

.footer-no-more {
    color: #d1d5db;
    letter-spacing: 1px;
}

.loading-spinner {
    width: 16px;
    height: 16px;
    border: 2px solid #e5e7eb;
    border-top-color: #3b82f6;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}
