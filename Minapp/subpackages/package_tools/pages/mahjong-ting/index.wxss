page {
  --primary: #667eea;
  --bg-page: #F7F8FA;
  --bg-card: #FFFFFF;
  --text-main: #1A1A1A;
  --text-secondary: #6B7280;
  --teal: #4fd1c5;
  --shadow-md: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.page-container {
  min-height: 100vh;
  background: var(--bg-page);
}

.custom-nav {
  position: fixed;
  top: env(safe-area-inset-top);
  left: 0;
  right: 0;
  height: 88rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 20;
  box-shadow: 0 1rpx 0 rgba(15, 23, 42, 0.06);
}

.nav-title-wrap {
  position: relative;
  width: 100%;
  text-align: center;
}

.back-icon {
  position: absolute;
  left: 24rpx;
  top: -4rpx;
  font-size: 46rpx;
  color: #111827;
  line-height: 1;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.content-area {
  height: 100vh;
  box-sizing: border-box;
  padding: calc(env(safe-area-inset-top) + 108rpx) 0 24rpx;
}

.card {
  background: var(--bg-card);
  border-radius: 24rpx;
  box-shadow: var(--shadow-md);
  margin: 0 16rpx 16rpx;
  padding: 22rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.section-stick {
  width: 8rpx;
  height: 30rpx;
  border-radius: 8rpx;
  background: var(--teal);
  flex-shrink: 0;
}

.section-title {
  font-size: 30rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #253b56;
}

.count-text {
  margin-left: 6rpx;
  font-size: 30rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #ef4444;
}

.tip-box {
  background: #eef2ff;
  border-radius: 14rpx;
  padding: 12rpx 14rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.tip-badge {
  height: 32rpx;
  padding: 0 12rpx;
  border-radius: 16rpx;
  background: rgba(102, 126, 234, 0.18);
  color: var(--primary);
  font-size: 20rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: #4b5563;
  line-height: 1.55;
}

.pool-group {
  margin-bottom: 12rpx;
}

.pool-group-title {
  display: block;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: #6b7280;
  font-weight: 600;
}

.tile-grid {
  display: grid;
  grid-template-columns: repeat(9, 1fr);
  gap: 8rpx;
}

.tile-btn,
.hand-cell {
  position: relative;
  border-radius: 12rpx;
  background: #f8fafc;
}

.tile-btn {
  border: 1px solid #e5e7eb;
  height: 116rpx;
  padding: 2rpx 2rpx 22rpx;
}

.tile-img {
  width: 100%;
  height: 100%;
  display: block;
}

.is-disabled {
  opacity: 0.4;
}

.is-laizi {
  box-shadow: 0 0 0 1px rgba(239, 68, 68, 0.45) inset;
  border-color: rgba(239, 68, 68, 0.4);
}

.laizi-ribbon {
  position: absolute;
  right: -18rpx;
  top: -6rpx;
  width: 76rpx;
  height: 28rpx;
  background: linear-gradient(135deg, #ff5b5b 0%, #e11d48 100%);
  border: 1px solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 2rpx 7rpx rgba(225, 29, 72, 0.26);
  display: flex;
  align-items: center;
  justify-content: center;
  transform: rotate(41deg);
  transform-origin: center;
  z-index: 4;
  pointer-events: none;
}

.laizi-ribbon-text {
  color: #fff;
  font-size: 12rpx;
  font-weight: 700;
  letter-spacing: 0;
  line-height: 1;
}

.count-chip {
  position: absolute;
  left: 50%;
  bottom: 5rpx;
  transform: translateX(-50%);
  min-width: 32rpx;
  height: 24rpx;
  border-radius: 12rpx;
  background: rgba(102, 126, 234, 0.12);
  border: 1px solid rgba(102, 126, 234, 0.26);
  color: #4f46e5;
  font-size: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  z-index: 5;
}

.hand-grid {
  display: grid;
  grid-template-columns: repeat(9, 1fr);
  gap: 8rpx;
}

.meld-editor {
  padding: 12rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1px solid #e5e7eb;
}

.meld-editor-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.meld-editor-row:last-child {
  margin-bottom: 0;
}

.meld-editor-label {
  width: 64rpx;
  font-size: 24rpx;
  color: #475569;
  font-weight: 600;
}

.meld-preview-row {
  min-width: 120rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meld-preview-tile {
  width: 38rpx;
  height: 52rpx;
}

.mini-action-btn {
  height: 56rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  padding: 0 14rpx;
  white-space: nowrap;
}

.picker-action-btn {
  background: #eef2ff;
  color: #4f46e5;
  border: 1px solid rgba(102, 126, 234, 0.2);
}

.add-action-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 6rpx 18rpx rgba(102, 126, 234, 0.26);
}

.picker-overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.35);
  display: flex;
  align-items: flex-end;
  z-index: 60;
}

.picker-panel {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  box-shadow: 0 -10rpx 40rpx rgba(15, 23, 42, 0.2);
  padding: 20rpx 20rpx 0;
  max-height: 72vh;
  display: flex;
  flex-direction: column;
}

.picker-header {
  padding-bottom: 14rpx;
}

.picker-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.picker-body {
  overflow-y: auto;
}

.picker-subtitle {
  margin: 8rpx 0;
  font-size: 24rpx;
  color: #475569;
  font-weight: 600;
}

.picker-suit-row {
  display: flex;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.picker-suit-item {
  flex: 1;
  border-radius: 12rpx;
  border: 1px solid #e2e8f0;
  background: #f8fafc;
  padding: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.picker-suit-item.selected,
.picker-chi-item.selected,
.picker-tile-item.selected {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  box-shadow: 0 0 0 1px rgba(102, 126, 234, 0.18) inset;
}

.picker-suit-image {
  width: 40rpx;
  height: 56rpx;
}

.picker-suit-text {
  font-size: 22rpx;
  color: #374151;
}

.picker-chi-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
}

.picker-chi-item {
  border-radius: 12rpx;
  border: 1px solid #e2e8f0;
  background: #f8fafc;
  padding: 8rpx 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.picker-chi-tile {
  width: 34rpx;
  height: 48rpx;
}

.picker-tile-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.picker-tile-item {
  border-radius: 10rpx;
  border: 1px solid #e2e8f0;
  background: #f8fafc;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rpx;
}

.picker-tile-image {
  width: 100%;
  height: 100%;
}

.picker-actions {
  margin-top: 16rpx;
  display: flex;
  gap: 12rpx;
}

.picker-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}

.picker-btn-secondary {
  background: #f3f4f6;
  color: #4b5563;
}

.picker-btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.28);
}

.picker-safe-space {
  height: calc(16rpx + env(safe-area-inset-bottom));
}

.meld-list {
  margin-top: 14rpx;
}

.meld-item {
  border-radius: 12rpx;
  border: 1px solid #e2e8f0;
  background: #fff;
  padding: 10rpx;
  margin-bottom: 10rpx;
}

.meld-item-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.meld-tag {
  height: 30rpx;
  padding: 0 12rpx;
  border-radius: 16rpx;
  background: rgba(102, 126, 234, 0.16);
  color: #667eea;
  font-size: 20rpx;
  font-weight: 600;
}

.meld-remove {
  font-size: 22rpx;
  color: #ef4444;
}

.meld-tiles {
  display: flex;
  gap: 8rpx;
}

.meld-tile {
  position: relative;
  width: 86rpx;
  height: 116rpx;
  border-radius: 10rpx;
  border: 1px solid #e5e7eb;
  background: #f8fafc;
  padding: 2rpx;
}

.empty-meld-tip {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.hand-cell {
  border: 1px dashed #d7dce2;
  height: 126rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rpx;
}

.cell-empty {
  background: #f9fafb;
}

.empty-slot-inner {
  width: 74%;
  height: 84rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
}

.action-row {
  margin-top: 18rpx;
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
}

.clear-btn {
  height: 64rpx;
  min-width: 200rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.32);
}

.clear-light {
  background: #f3f4f6;
  color: #475569;
  box-shadow: none;
}

.btn-disabled {
  opacity: 0.45;
}

.result-state {
  font-size: 34rpx;
  font-weight: 700;
}

.state-ok {
  color: #dc2626;
}

.state-no {
  color: #475569;
}

.result-panel {
  display: flex;
  border-radius: 12rpx;
  overflow: hidden;
  background: #eef2ff;
  border-left: 6rpx solid var(--teal);
}

.result-left {
  width: 118rpx;
  padding-top: 18rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #ef4444;
  background: rgba(255, 255, 255, 0.46);
}

.result-right {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 10rpx;
}

.result-tile-item {
  width: 92rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-tile-img {
  width: 92rpx;
  height: 140rpx;
  border-radius: 10rpx;
  border: 1px solid rgba(2, 6, 23, 0.06);
  background: #fff;
}

.result-remain {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #334155;
}
