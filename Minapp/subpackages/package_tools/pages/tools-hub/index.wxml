<view class="page-container">
  <view class="custom-nav">
    <view class="back-btn" bindtap="handleBack">
      <text class="back-icon">‹</text>
      <text class="back-text">棋牌工具</text>
    </view>
  </view>

  <scroll-view class="content-area" scroll-y="true">
    <view class="section-title">工具列表</view>

    <view
      wx:for="{{toolCards}}"
      wx:key="id"
      wx:for-item="tool"
      class="skill-card tool-card"
      bindtap="openTool"
      data-path="{{tool.path}}"
    >
      <view class="card-row">
        <view class="card-icon-wrap">
          <image
            wx:if="{{!toolIconErrorMap[tool.id]}}"
            class="card-icon-img"
            src="{{tool.icon}}"
            mode="aspectFit"
            data-id="{{tool.id}}"
            binderror="onToolIconError"
            aria-label="{{tool.iconAlt}}"
          />
          <text wx:else class="card-icon-text">{{tool.iconFallback}}</text>
        </view>
        <view class="card-main">
          <text class="card-title">{{tool.name}}</text>
          <text class="card-desc">{{tool.desc}}</text>
        </view>
      </view>
      <text class="card-arrow">›</text>
    </view>
  </scroll-view>
</view>
