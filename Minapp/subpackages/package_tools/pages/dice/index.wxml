<view class="page-container">
  <view class="custom-nav">
    <view class="nav-title-wrap">
      <text class="back-icon" bindtap="handleBack">‹</text>
      <text class="nav-title">掷骰子</text>
    </view>
  </view>

  <scroll-view class="content-area" scroll-y="true">
    <view class="card section-card">
      <view class="section-title-row">
        <view class="section-stick"></view>
        <text class="section-title">掷骰设置</text>
      </view>

      <view class="compact-control-row">
        <text class="control-label">骰子个数</text>
        <view class="count-stepper-row">
          <view class="step-btn {{rolling || diceCount <= 1 ? 'btn-disabled' : ''}}" bindtap="onDecreaseDiceCount">-</view>
          <input class="step-input" type="number" value="{{diceCount}}" disabled />
          <view class="step-btn {{rolling || diceCount >= 2 ? 'btn-disabled' : ''}}" bindtap="onIncreaseDiceCount">+</view>
        </view>
        <text class="step-limit">1~2</text>
      </view>

      <view class="action-row">
        <view class="primary-btn {{rolling ? 'btn-disabled is-rolling' : ''}}" bindtap="onRoll">{{rolling ? '掷骰中...' : '开始掷骰'}}</view>
        <view class="secondary-btn {{history.length && !rolling ? '' : 'btn-disabled'}}" bindtap="onClearHistory">清空历史</view>
      </view>
    </view>

    <view class="card section-card result-card">
      <view class="section-title-row">
        <view class="section-stick"></view>
        <text class="section-title">当前结果</text>
      </view>

      <view class="result-stage">
        <view wx:if="{{cubeViews.length}}" class="cube-stage">
          <view
            wx:for="{{cubeViews}}"
            wx:key="id"
            wx:for-item="cube"
            class="cube-wrap"
          >
            <view
              class="dice-cube {{cube.rolling ? 'is-rolling' : ''}} {{cube.rollClass}} {{cube.settling ? 'is-settling' : ''}}"
              style="{{cube.styleText}} transform: {{cube.transform}};"
            >
              <view wx:for="{{cube.faces}}" wx:key="key" wx:for-item="face" class="cube-face cube-face-{{face.key}}">
                <view wx:for="{{face.pips}}" wx:key="*this" class="pip {{item}}"></view>
              </view>
            </view>
          </view>
        </view>

        <view class="status-gap"></view>

        <view class="status-text {{currentValues.length ? 'is-result' : ''}}">
          <block wx:if="{{currentValues.length}}">
            总点数：<text class="sum-value">{{currentSum}}</text>
          </block>
          <block wx:else>
            {{rolling ? '骰子滚动中...' : '点击“开始掷骰”生成结果'}}
          </block>
        </view>
      </view>
    </view>

    <view class="card section-card history-card">
      <view class="section-title-row">
        <view class="section-stick"></view>
        <text class="section-title">历史记录</text>
        <text class="count-text">[{{history.length}}/20]</text>
      </view>

      <view wx:if="{{!history.length}}" class="empty-text">暂无历史记录</view>

      <view wx:if="{{history.length}}" class="history-list">
        <view wx:for="{{history}}" wx:key="id" wx:for-item="record" class="history-item">
          <view class="history-left">
            <text class="history-time">{{record.timeText}}</text>
            <text class="history-values">{{record.diceText}}</text>
          </view>
          <view class="history-right">
            <text class="history-sum">{{record.sum}}</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
