page {
    height: 100%;
    overflow: hidden;
    background-color: #f6f7f9;
}

/* Base Card - Common */
.card-base {
    background-color: white;
    border-radius: 24rpx;
    padding: 32rpx;
    margin-bottom: 24rpx;
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
    position: relative;
    overflow: hidden;
    border: 1rpx solid #f3f4f6;
}

/* Header Card Refined */
.header-card-refined {
    background: linear-gradient(135deg, #FFFFFF 0%, #F5FAFF 100%); /* Refined and lighter */
    margin-top: 240rpx; 
    padding: 32rpx !important;
    border: 1rpx solid rgba(59, 130, 246, 0.15); /* Delicate border */
    box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.08);
}
.header-card-refined::after {
    content: "👥";
    position: absolute;
    bottom: -10rpx;
    right: 10rpx;
    font-size: 100rpx;
    opacity: 0.05;
    transform: rotate(-10deg);
    pointer-events: none;
}
.club-name-premium {
    font-size: 38rpx;
    font-weight: 900;
    color: #0f172a;
    line-height: 1.2;
}

.id-badge-subtle {
    font-size: 18rpx;
    background-color: #f1f5f9;
    color: #64748b;
    padding: 2rpx 10rpx;
    border-radius: 6rpx;
    font-family: monospace;
    font-weight: 500;
}

.club-description-box {
    margin-top: 20rpx;
    margin-bottom: 24rpx;
    padding-left: 20rpx;
    border-left: 4rpx solid #3b82f6;
    position: relative;
    z-index: 1;
}

.club-description-text {
    font-size: 24rpx;
    color: #475569;
    line-height: 1.6;
    display: block;
}

.header-btn {
    margin: 0 !important;
    padding: 10rpx 0 !important; /* Remove horizontal padding, usage fixed width */
    width: 140rpx; /* Fixed width for alignment */
    line-height: 1.4 !important;
    border-radius: 999rpx;
    font-size: 24rpx;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none !important;
}

.header-btn-blue {
    background: #3b82f6 !important;
    color: white !important;
    box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.header-btn-red {
    background: #ef4444 !important;
    color: white !important;
    box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.3);
}

.header-btn-gray {
    background: #f1f5f9 !important;
    color: #475569 !important;
    border: 1rpx solid #e2e8f0 !important;
}

.divider-fade {
    height: 1rpx;
    background: linear-gradient(90deg, rgba(226, 232, 240, 0) 0%, #E2E8F0 50%, rgba(226, 232, 240, 0) 100%);
    width: 100%;
    margin: 24rpx 0;
}
.stats-card-champion {
    background: linear-gradient(135deg, #FFF1CC 0%, #FFFFFF 100%); /* More vibrant Gold */
    border-color: #FFD700;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 24rpx 12rpx !important;
    min-height: 200rpx !important;
    margin-bottom: 24rpx; /* Shift up relative to next row if any */
}
.stats-card-champion::after {
    content: "👑";
    position: absolute;
    bottom: 0rpx;
    right: 0rpx;
    font-size: 110rpx;
    opacity: 0.15; /* Increased */
    transform: rotate(15deg);
    pointer-events: none;
}

.stats-card-winrate {
    background: linear-gradient(135deg, #EBF5FF 0%, #FFFFFF 100%); /* More vibrant Blue */
    border-color: #3b82f6;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 28rpx 12rpx !important;
    min-height: 220rpx !important;
}
.stats-card-winrate::after {
    content: "🔥";
    position: absolute;
    bottom: 0rpx;
    right: 0rpx;
    font-size: 110rpx;
    opacity: 0.15; /* Increased */
    transform: rotate(-10deg);
    pointer-events: none;
}

.stats-title {
    font-size: 32rpx; /* Enlarged per objective */
    font-weight: 800;
    margin-bottom: 12rpx;
    width: 100%;
    text-align: center;
    position: relative;
    z-index: 1;
    letter-spacing: 1rpx;
}

.stats-value-box {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    margin-bottom: 20rpx;
    position: relative;
    z-index: 1;
}

.stats-value-large {
    font-size: 56rpx;
    margin-top: 12rpx; /* Move down */
    font-weight: 900;
    line-height: 1;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
}

.stats-label-small {
    font-size: 18rpx;
    color: #94a3b8;
    margin-bottom: 2rpx;
    text-transform: uppercase;
    letter-spacing: 2rpx;
    font-weight: bold;
}

.player-name-hero {
    font-size: 32rpx; /* Enlarged for prominence */
    font-weight: 700;
    color: #1a1a1a;
}

.avatar-honor-gold {
    border: 3rpx solid #FFD700 !important;
    box-shadow: 0 0 12rpx rgba(255, 215, 0, 0.5);
}

.avatar-honor-blue {
    border: 3rpx solid #3b82f6 !important;
    box-shadow: 0 0 12rpx rgba(59, 130, 246, 0.4);
}

.player-info-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 12rpx;
    width: 100%;
    position: relative;
    z-index: 1;
}

/* Rules Hint */
.rules-hint {
    position: absolute;
    top: 24rpx;
    right: 24rpx;
    font-size: 28rpx;
    color: #94a3b8;
    opacity: 0.5;
    cursor: pointer;
}

/* Stats Detail */
.stats-detail {
    font-size: 20rpx;
    color: #94a3b8;
    margin-left: 8rpx;
}

/* 缓存相关样式 */
.cache-icon {
    position: absolute;
    top: 24rpx;
    right: 24rpx;
    font-size: 28rpx;
    color: #94a3b8;
    opacity: 0.5;
    cursor: pointer;
    padding: 8rpx;
}

/* 刷新相关样式 */
.refresher-bg {
    background-color: #f6f7f9;
}


/* Customized Pill Back Button */
.back-btn-pill {
    padding: 0 28rpx 0 20rpx !important;
    gap: 4rpx;
}

.back-btn-text {
    font-size: 26rpx;
    font-weight: 600;
    color: #111827;
    margin-bottom: 2rpx; /* Visual alignment */
}

/* History Card Refined */
.history-card {
    background-color: white;
    border-radius: 8rpx;
    padding: 12rpx 20rpx !important; 
    margin-bottom: 12rpx !important;
    box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.02);
    border: 1rpx solid #f3f5f8;
    position: relative;
    overflow: hidden;
    min-height: 0 !important; /* Remove any minimum height constraints */
}
.history-card::after {
    content: "📝";
    position: absolute;
    top: 5rpx;
    right: 15rpx;
    font-size: 60rpx; /* Smaller */
    opacity: 0.04;
    pointer-events: none;
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4rpx !important; /* Minimized */
    position: relative;
    z-index: 1;
}

.time-wrapper {
    display: flex;
    align-items: center;
    gap: 4rpx;
    color: #94a3b8;
    font-size: 22rpx; /* Scaled down */
    font-weight: 500;
}
.calendar-icon { font-size: 24rpx; } /* Scaled down */

.round-badge {
    background-color: #f0f7ff;
    color: #3b82f6;
    font-size: 20rpx; /* Scaled down */
    font-weight: bold;
    padding: 2rpx 10rpx; /* Tighter */
    border-radius: 4rpx;
}

.players-row {
    display: flex;
    gap: 24rpx;
    overflow-x: auto;
    position: relative;
    z-index: 1;
}

.player-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 110rpx; 
    padding: 0;
    margin: 0;
}

.history-avatar {
    width: 44rpx !important; 
    height: 44rpx !important;
    border-radius: 4rpx;
    background-color: #f3f4f6;
    margin-bottom: 1rpx;
}

.player-name-sm {
    font-size: 22rpx !important; 
    color: #64748b;
    margin-top: 1rpx;
    margin-bottom: 0rpx;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 110rpx;
    text-align: center;
}

.score-text {
    font-size: 24rpx; 
    font-weight: bold;
    font-family: 'Inter', monospace;
    line-height: 1;
}

.text-orange { color: #f97316; }
.text-green { color: #22c55e; }
.text-gray { color: #9ca3af; }

.member-preview-stack-item {
    width: 44rpx;
    height: 44rpx;
    border-radius: 50%;
    border: 2rpx solid #ffffff;
    background-color: #f3f4f6;
    margin-right: -10rpx;
    box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

/* Modal Styles */
.modal-overlay {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4rpx);
}

.modal-content {
    width: 600rpx;
    background-color: #ffffff;
    border-radius: 32rpx;
    padding: 40rpx;
    box-sizing: border-box;
    box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20rpx;
}

.close-btn {
    font-size: 48rpx;
    color: #94a3b8;
    padding: 10rpx;
}

.join-input-field {
    background-color: #f1f5f9;
    height: 100rpx;
    border-radius: 20rpx;
    padding: 0 32rpx;
    font-size: 40rpx;
    font-weight: bold;
    color: #1e293b;
    letter-spacing: 4rpx;
}

/* Scrolling Fix */
.flex-1.w-full {
    flex: 1;
    min-height: 0;
    height: 0;
    display: block;
}

/* Numeric Club ID Highlight */
.club-id-highlight {
    font-size: 32rpx;
    font-weight: bold;
    color: #3b82f6; /* Blue-500 */
    margin-top: 4rpx;
    letter-spacing: 1rpx;
}

/* Skeleton Loading Effects */
.skeleton {
    position: relative;
    overflow: hidden;
    background-color: #f1f5f9;
    border-radius: 8rpx;
    color: transparent !important;
}

.skeleton::after {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(90deg, 
        rgba(255,255,255,0) 0%, 
        rgba(255,255,255,0.6) 50%, 
        rgba(255,255,255,0) 100%
    );
    animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
}

.fade-in {
    animation: fadeIn 0.5s ease-out forwards;
}

@keyframes fadeIn {
    from { opacity: 0; filter: blur(4px); }
    to { opacity: 1; filter: blur(0); }
}

.skeleton-text-lg { height: 48rpx; width: 80%; }
.skeleton-text-sm { height: 32rpx; width: 60%; }
.skeleton-avatar { height: 48rpx; width: 48rpx; border-radius: 50%; }
