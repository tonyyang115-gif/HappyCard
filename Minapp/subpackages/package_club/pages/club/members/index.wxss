.container {
    padding: 0;
    background-color: #f6f7f9;
    min-height: 100vh;
}

/* 搜索栏样式 */
.search-bar {
    background: white;
    padding: 20rpx 24rpx;
    margin: 0;
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.search-input-wrapper {
    display: flex;
    align-items: center;
    background: #f5f7fa;
    border-radius: 20rpx;
    padding: 0 20rpx;
    gap: 16rpx;
}

.search-icon {
    font-size: 28rpx;
}

.search-input {
    flex: 1;
    height: 70rpx;
    font-size: 28rpx;
    background: transparent;
    border: none;
}

.clear-icon {
    font-size: 28rpx;
    color: #94a3b8;
    padding: 8rpx;
}

/* 加载状态样式 */
.loading-state {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    padding: 40rpx 0;
}

.skeleton {
    position: relative;
    overflow: hidden;
    background-color: #f1f5f9;
    border-radius: 8rpx;
}

.skeleton::after {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(90deg, 
        rgba(255,255,255,0) 0%, 
        rgba(255,255,255,0.6) 50%, 
        rgba(255,255,255,0) 100%
    );
    animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
}

.load-more-indicator {
    padding: 40rpx 0;
    text-align: center;
    border-top: 1rpx solid #f1f5f9;
    margin-top: 20rpx;
}

.no-more-indicator {
    padding: 40rpx 0;
    text-align: center;

}

/* Tab Styles */
.tabs-header {
    display: flex;
    background: #fff;
    padding: 0 32rpx;
    border-bottom: 1rpx solid #eee;
    position: sticky;
    top: 0;
    z-index: 10;
}

.tab-item {
    padding: 24rpx 0;
    margin-right: 48rpx;
    position: relative;
    font-size: 28rpx;
    color: #64748b;
    transition: all 0.2s ease;
}

.tab-item.active {
    color: #3b82f6;
    font-weight: bold;
    font-size: 30rpx;
}

.indicator {
    position: absolute;
    bottom: 0;
    left: 20%;
    width: 60%;
    height: 6rpx;
    background: #3b82f6;
    border-radius: 4rpx;
}

/* Settings Form Styles */
.border-red-100 {
    border-color: #fee2e2;
}

.shadow-blue {
    box-shadow: 0 4rpx 14rpx 0 rgba(59, 130, 246, 0.3);
}


.member-list {
    background-color: #fff;
    margin-top: 20rpx;
}

.member-item {
    display: flex;
    align-items: center;
    padding: 30rpx;
    border-bottom: 1rpx solid #f1f5f9;
}

.member-item:last-child {
    border-bottom: none;
}

.member-avatar {
    width: 100rpx;
    height: 100rpx;
    border-radius: 50%;
    margin-right: 30rpx;
    background-color: #f1f5f9;
}

.member-info {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.member-name {
    font-size: 32rpx;
    font-weight: 500;
    color: #1e293b;
}

.badge-owner {
    font-size: 20rpx;
    color: #fff;
    background-color: #f59e0b;
    padding: 2rpx 10rpx;
    border-radius: 8rpx;
}

.remove-btn {
    padding: 10rpx 24rpx;
    border: 1rpx solid #fee2e2;
    background-color: #fef2f2;
    color: #ef4444;
    font-size: 26rpx;
    border-radius: 30rpx;
    font-weight: 500;
}

.remove-btn:active {
    opacity: 0.7;
}

.empty-state {
    padding: 100rpx 0;
    text-align: center;
}

