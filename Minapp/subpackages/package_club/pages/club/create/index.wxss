/* Standard App Form Styles matching Room Page */
page {
    /* Exact gradient from room/index.wxss */
    background: linear-gradient(180deg, #dce9ff 0%, #f5f7fa 25%, #f5f7fa 100%);
    min-height: 100vh;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  }
  
  .page-container {
    padding-bottom: 40px;
    box-sizing: border-box;
  }
  
  .club-input {
    background: #f3f4f6;
    padding: 0 24rpx;
    height: 100rpx; /* Increased height for comfort */
    border-radius: 12rpx; 
    width: 100%;
    box-sizing: border-box;
    font-size: 32rpx;
    color: #111827;
  }
  
  .club-form-card {
      background: white;
      border-radius: 24rpx; /* Slightly more rounded */
      padding: 40rpx; /* More padding */
      /* box-shadow removed to avoid color bleeding */
      position: relative;
      z-index: 10;
  }
  
  /* Avatar Trigger Styles */
  .club-avatar-trigger {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      height: 100%;
  }

  .club-avatar-trigger-img {
      width: 96rpx;
      height: 96rpx;
      border-radius: 50%;
      background-color: #e5e7eb;
      margin-right: 24rpx;
  }

  /* Modal Styles - Prefixed to prevent conflicts */
  .club-modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 900; /* High z-index */
      visibility: hidden;
      opacity: 0;
      transition: all 0.3s;
  }

  .club-modal-overlay.show {
      visibility: visible;
      opacity: 1;
  }

  .club-modal-content {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      background: white;
      border-radius: 24rpx 24rpx 0 0;
      padding: 40rpx;
      z-index: 901; /* Higher than overlay */
      transform: translateY(100%);
      transition: transform 0.3s cubic-bezier(0.19, 1, 0.22, 1);
      padding-bottom: env(safe-area-inset-bottom);
  }

  .club-modal-content.show {
      transform: translateY(0);
  }

  /* Helper Classes for Grid */
  .club-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24rpx;
      padding: 10rpx;
  }
  
  .club-avatar-option {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 4rpx;
  }

  .club-avatar-img {
      width: 100rpx;
      height: 100rpx;
      border-radius: 50%;
  }

  /* Avatar Action Cards */
  .club-action-row {
      display: flex;
      flex-direction: row;
      justify-content: space-between;
      gap: 24rpx;
      margin-bottom: 40rpx;
  }

  .club-action-card {
      flex: 1;
      height: 160rpx;
      border-radius: 20rpx;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
  }

  .club-upload-card {
      background-color: #eff6ff; /* blue-50 */
      border: 2rpx dashed #3b82f6; /* blue-500 */
  }

  .club-preview-card {
      background-color: #f9fafb; /* gray-50 */
      border: 2rpx solid #e5e7eb; /* gray-200 */
  }
  
  .club-upload-icon {
      font-size: 48rpx;
      margin-bottom: 8rpx;
      color: #3b82f6;
  }

  .club-preview-label {
      font-size: 24rpx;
      color: #6b7280;
      margin-bottom: 8rpx;
  }

  .club-preview-large {
      width: 80rpx;
      height: 80rpx;
      border-radius: 50%;
      border: 2rpx solid white;
      box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  }
  
  .club-avatar-preview {
      width: 64rpx;
      height: 64rpx;
      border-radius: 50%;
      background-color: #f3f4f6;
  }

  .h-safe-bottom {
      height: env(safe-area-inset-bottom);
  }

  /* Fade In Animation */
  .fade-in {
      animation: fadeIn 0.6s ease-out forwards;
      opacity: 0;
      transform: translateY(20rpx);
  }
  
  @keyframes fadeIn {
      to {
          opacity: 1;
          transform: translateY(0);
      }
  }

  /* Modal Styles */
  .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 100;
      visibility: hidden;
      opacity: 0;
      transition: all 0.3s;
  }

  .modal-overlay.show {
      visibility: visible;
      opacity: 1;
  }

  .modal-content-bottom {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      background: white;
      border-radius: 24rpx 24rpx 0 0;
      padding: 40rpx;
      z-index: 101;
      transform: translateY(100%);
      transition: transform 0.3s cubic-bezier(0.19, 1, 0.22, 1);
      padding-bottom: env(safe-area-inset-bottom);
  }

  .modal-content-bottom.show {
      transform: translateY(0);
  }

  .h-safe-bottom {
      height: env(safe-area-inset-bottom);
  }