.pt-24 { padding-top: calc(60px + env(safe-area-inset-top)); }
.px-6 { padding-left: 1.5rem; padding-right: 1.5rem; }
.w-full { width: 100%; }
.max-w-xs { max-width: 20rem; }
.max-w-200 { max-width: 200px; }
.gap-2 { gap: 0.5rem; }
.gap-4 { gap: 1rem; }
.mb-4 { margin-bottom: 1rem; }
.mb-8 { margin-bottom: 2rem; }
.mb-20 { margin-bottom: 5rem; }
.mt-8 { margin-top: 2rem; }
.pb-10 { padding-bottom: 2.5rem; }
.pb-0.5 { padding-bottom: 0.125rem; }
.p-2 { padding: 0.5rem; }
.p-0.5 { padding: 0.125rem; }

.border-4 { border-width: 4px; }
.border-b { border-bottom-width: 1px; }
.border-gray-400 { border-color: #9ca3af; }
.border-white { border-color: #ffffff; }

.bg-blue-500 { background-color: #3b82f6; }
.text-blue-500 { color: #3b82f6; }
.text-white { color: #ffffff; }
.text-center { text-align: center; }
.leading-tight { line-height: 1.25; }

.shadow-blue { box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.2); }

.container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

.home-main {
    min-height: 0;
    flex: 1;
    box-sizing: border-box;
    padding-bottom: 20rpx;
}

.actions-wrap {
    margin-bottom: 22rpx;
}

.profile-name-row {
    margin-bottom: 20rpx;
}

.profile-edit-tip {
    margin-bottom: 42rpx;
}

.mini-code-share-card {
    width: 100%;
    max-width: 640rpx;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 22rpx;
    padding: 18rpx 22rpx;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    margin-bottom: 18rpx;
    box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.06);
    max-height: 160rpx;
    overflow: hidden;
    transition: transform 0.2s ease;
}

.mini-code-share-card:active {
    transform: scale(0.99);
}

.mini-code-thumb,
.mini-code-fallback {
    width: 112rpx;
    height: 112rpx;
    border-radius: 16rpx;
    flex-shrink: 0;
}

.mini-code-thumb {
    border: 1px solid #e5e7eb;
}

.mini-code-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #64748b;
    font-size: 32rpx;
    background: #f8fafc;
}

.mini-code-share-text {
    display: flex;
    flex-direction: column;
    margin-left: 20rpx;
    gap: 6rpx;
}

.mini-code-share-title {
    color: #1f2937;
    font-size: 30rpx;
    font-weight: 700;
    line-height: 1.2;
}

.mini-code-share-desc {
    color: #4b5563;
    font-size: 24rpx;
    line-height: 1.3;
}

.mini-code-share-hint {
    color: #6b7280;
    font-size: 22rpx;
    line-height: 1.2;
}

.action-btn-content {
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.action-btn-label {
    font-size: inherit;
    font-weight: inherit;
    line-height: 1;
}

.action-btn-icon {
    margin-left: 12rpx;
    font-size: 30rpx;
    line-height: 1;
    width: 32rpx;
    text-align: center;
}

.brand-row {
    width: 100%;
    margin-top: 12rpx;
}

.brand-icon-wrap {
    width: 70rpx;
    height: 70rpx;
    border-radius: 12rpx;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
}

.brand-icon {
    width: 100%;
    height: 100%;
}

.help-link {
    margin-top: 16rpx;
    margin-bottom: 20rpx;
}

.edit-icon-bg {
    position: absolute;
    bottom: 0;
    right: 0;
    background-color: white;
    border-radius: 9999px;
    padding: 0.375rem;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    border: 1px solid #f3f4f6;
    display: flex;
    align-items: center;
    justify-content: center;
}
.edit-icon {
    font-size: 12px;
    color: #4b5563;
}



/* Modal */
.modal-overlay {
    position: fixed;
    inset: 0;
    background-color: rgba(0,0,0,0.5);
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
}

.share-panel-overlay {
    position: fixed;
    inset: 0;
    z-index: 80;
    background: rgba(0, 0, 0, 0.42);
    display: flex;
    align-items: flex-end;
}

.share-panel {
    width: 100%;
    background: #ffffff;
    border-top-left-radius: 26rpx;
    border-top-right-radius: 26rpx;
    padding: 28rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
    box-sizing: border-box;
}

.share-panel-title {
    display: block;
    text-align: center;
    font-size: 32rpx;
    font-weight: 700;
    color: #111827;
    margin-bottom: 24rpx;
}

.share-panel-btn {
    width: 100%;
    border-radius: 16rpx;
    margin-bottom: 16rpx;
    border: none;
    line-height: 88rpx;
    font-size: 30rpx;
}

.share-panel-btn::after {
    border: none;
}

.share-panel-primary {
    background: #3b82f6;
    color: #ffffff;
}

.share-panel-secondary {
    background: #eff6ff;
    color: #1d4ed8;
}

.share-panel-cancel {
    background: #f3f4f6;
    color: #4b5563;
    margin-bottom: 0;
}

@media (max-width: 375px) {
    .pt-24 {
        padding-top: calc(42px + env(safe-area-inset-top));
    }

    .profile-edit-tip {
        margin-bottom: 28rpx;
    }

    .mini-code-share-card {
        padding: 14rpx 16rpx;
        max-height: 138rpx;
    }

    .mini-code-thumb,
    .mini-code-fallback {
        width: 92rpx;
        height: 92rpx;
    }

    .mini-code-share-text {
        margin-left: 14rpx;
        gap: 4rpx;
    }

    .mini-code-share-title {
        font-size: 28rpx;
    }

    .mini-code-share-desc {
        font-size: 22rpx;
    }

    .mini-code-share-hint {
        font-size: 20rpx;
    }
}
.modal-content {
    background-color: white;
    width: 100%;
    max-width: 320px;
    border-radius: 1rem;
    padding: 1.5rem;
    animation: zoomIn 0.2s ease-out;
    display: flex;
    flex-direction: column;
}
.modal-header {
    display: flex;
    justify-content: center; /* Center the title */
    align-items: center;
    position: relative; /* For absolute positioning of close btn */
    margin-bottom: 1rem;
}
.close-btn {
    position: absolute;
    right: 0;
    font-size: 1.5rem;
    color: #9ca3af;
    padding: 0.5rem;
    line-height: 1;
}
.input-field {
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    padding: 0.5rem;
    flex: 1;
}

/* Avatar Grid */
.avatar-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
    margin-top: 0.5rem;
}
.avatar-item {
    border-radius: 50%;
    /* overflow: hidden; -- Remove this so border isn't clipped if there's padding, or keep it if we want the border to follow the radius. With padding, the border is strictly on the div. */
    overflow: hidden; 
    border: 2px solid transparent;
    transition: all 0.2s;
    padding: 2px; /* Add space between avatar and potential border */
    box-sizing: border-box; /* Ensure size includes padding/border */
    
    /* Fix for circular border in grid: prevent stretching */
    justify-self: center;
    align-self: center;
    display: inline-flex; /* content-hugging */
}
.avatar-item.selected {
    border-color: #3b82f6;
    /* transform: scale(1.1); -- Maybe reduce scale or remove if padding makes it big enough? Let's keep scale for emphasis but ensure it doesn't break layout */
    transform: scale(1.1);
}

.modal-footer {
    display: flex;
    justify-content: center; /* Center buttons */
    gap: 1rem;
    margin-top: 1.5rem;
}

@keyframes zoomIn {
    from { transform: scale(0.95); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
}

/* Help Modal Specifics */
.help-swipe-shell {
    width: 100%;
    max-height: 60vh;
    height: 60vh;
    border-radius: 18rpx;
    overflow: hidden;
    background: #f8fafc;
    touch-action: pan-y;
}

.help-swipe-image {
    width: 100%;
    border-radius: 18rpx;
    box-shadow: var(--shadow-md);
    transition: opacity 0.18s ease, transform 0.18s ease;
}

.help-swipe-image-animating {
    opacity: 0.92;
    transform: scale(0.992);
}

.help-pager-wrap {
    margin-top: 24rpx;
    margin-bottom: 8rpx;
    width: 100%;
    display: flex;
    justify-content: center;
}

.page-indicator {
    font-variant-numeric: tabular-nums;
}

/* UI Skill Generated Styles */
page {
  --primary: #667eea;
  --bg-page: #F7F8FA;
  --bg-card: #FFFFFF;
  --text-primary: #1A1A1A;
  --text-secondary: #999999;
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.skill-btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.skill-btn-primary:active {
  transform: scale(0.96);
}

.skill-btn-secondary {
  background: #FFFFFF;
  color: #667eea;
  border: 1px solid rgba(102, 126, 234, 0.2);
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.skill-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: var(--shadow-md);
  padding: 32rpx;
}

