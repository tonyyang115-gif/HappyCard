.pt-24 { padding-top: calc(60px + env(safe-area-inset-top)); }
.px-6 { padding-left: 1.5rem; padding-right: 1.5rem; }
.w-full { width: 100%; }
.max-w-xs { max-width: 20rem; }
.max-w-200 { max-width: 200px; }
.gap-2 { gap: 0.5rem; }
.gap-4 { gap: 1rem; }
.mb-4 { margin-bottom: 1rem; }
.mb-8 { margin-bottom: 2rem; }
.mb-20 { margin-bottom: 5rem; }
.mt-8 { margin-top: 2rem; }
.pb-10 { padding-bottom: 2.5rem; }
.pb-0.5 { padding-bottom: 0.125rem; }
.p-2 { padding: 0.5rem; }
.p-0.5 { padding: 0.125rem; }

.border-4 { border-width: 4px; }
.border-b { border-bottom-width: 1px; }
.border-gray-400 { border-color: #9ca3af; }
.border-white { border-color: #ffffff; }

.bg-blue-500 { background-color: #3b82f6; }
.text-blue-500 { color: #3b82f6; }
.text-white { color: #ffffff; }
.text-center { text-align: center; }
.leading-tight { line-height: 1.25; }

.shadow-blue { box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.2); }

.home-main {
    min-height: calc(100vh - 220rpx);
    box-sizing: border-box;
}

.actions-wrap {
    margin-bottom: 32rpx;
}

.action-btn-content {
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.action-btn-label {
    font-size: inherit;
    font-weight: inherit;
    line-height: 1;
}

.action-btn-icon {
    margin-left: 12rpx;
    font-size: 30rpx;
    line-height: 1;
    width: 32rpx;
    text-align: center;
}

.brand-row {
    width: 100%;
    margin-top: 20rpx;
}

.brand-icon-wrap {
    width: 70rpx;
    height: 70rpx;
    border-radius: 12rpx;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
}

.brand-icon {
    width: 100%;
    height: 100%;
}

.help-link {
    margin-top: 28rpx;
    margin-bottom: 36rpx;
}

.edit-icon-bg {
    position: absolute;
    bottom: 0;
    right: 0;
    background-color: white;
    border-radius: 9999px;
    padding: 0.375rem;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    border: 1px solid #f3f4f6;
    display: flex;
    align-items: center;
    justify-content: center;
}
.edit-icon {
    font-size: 12px;
    color: #4b5563;
}



/* Modal */
.modal-overlay {
    position: fixed;
    inset: 0;
    background-color: rgba(0,0,0,0.5);
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
}
.modal-content {
    background-color: white;
    width: 100%;
    max-width: 320px;
    border-radius: 1rem;
    padding: 1.5rem;
    animation: zoomIn 0.2s ease-out;
    display: flex;
    flex-direction: column;
}
.modal-header {
    display: flex;
    justify-content: center; /* Center the title */
    align-items: center;
    position: relative; /* For absolute positioning of close btn */
    margin-bottom: 1rem;
}
.close-btn {
    position: absolute;
    right: 0;
    font-size: 1.5rem;
    color: #9ca3af;
    padding: 0.5rem;
    line-height: 1;
}
.input-field {
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    padding: 0.5rem;
    flex: 1;
}

/* Avatar Grid */
.avatar-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
    margin-top: 0.5rem;
}
.avatar-item {
    border-radius: 50%;
    /* overflow: hidden; -- Remove this so border isn't clipped if there's padding, or keep it if we want the border to follow the radius. With padding, the border is strictly on the div. */
    overflow: hidden; 
    border: 2px solid transparent;
    transition: all 0.2s;
    padding: 2px; /* Add space between avatar and potential border */
    box-sizing: border-box; /* Ensure size includes padding/border */
    
    /* Fix for circular border in grid: prevent stretching */
    justify-self: center;
    align-self: center;
    display: inline-flex; /* content-hugging */
}
.avatar-item.selected {
    border-color: #3b82f6;
    /* transform: scale(1.1); -- Maybe reduce scale or remove if padding makes it big enough? Let's keep scale for emphasis but ensure it doesn't break layout */
    transform: scale(1.1);
}

.modal-footer {
    display: flex;
    justify-content: center; /* Center buttons */
    gap: 1rem;
    margin-top: 1.5rem;
}

@keyframes zoomIn {
    from { transform: scale(0.95); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
}

/* Help Modal Specifics */
.help-modal-content {
    max-width: 90%; /* Wider for images */
    padding: 1rem;
}

.instruction-img {
    width: 100%;
    border-radius: 8px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
}

.help-nav {
    margin-top: 1rem;
    padding: 0 0.5rem;
}

.nav-btn {
    padding: 0.5rem 1rem;
    background-color: #f3f4f6;
    border-radius: 0.5rem;
    color: #4b5563;
    font-size: 0.875rem;
    transition: all 0.2s;
}

.nav-btn:active {
    background-color: #e5e7eb;
}

.nav-btn.disabled {
    opacity: 0.5;
    pointer-events: none;
    color: #9ca3af;
}

.page-indicator {
    font-variant-numeric: tabular-nums;
}

/* UI Skill Generated Styles */
page {
  --primary: #667eea;
  --bg-page: #F7F8FA;
  --bg-card: #FFFFFF;
  --text-primary: #1A1A1A;
  --text-secondary: #999999;
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.skill-btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.skill-btn-primary:active {
  transform: scale(0.96);
}

.skill-btn-secondary {
  background: #FFFFFF;
  color: #667eea;
  border: 1px solid rgba(102, 126, 234, 0.2);
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.skill-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: var(--shadow-md);
  padding: 32rpx;
}

