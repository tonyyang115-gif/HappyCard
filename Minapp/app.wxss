/** app.wxss **/
page {
  background-color: #f6f7f9;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
} 

.flex-col { display: flex; flex-direction: column; }
.flex-row { display: flex; flex-direction: row; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }

/* Utility classes similar to Tailwind */
.bg-white { background-color: #ffffff; }
.text-gray-900 { color: #111827; }
.text-gray-400 { color: #9ca3af; }
.text-blue-500 { color: #3b82f6; }
.text-red-500 { color: #ef4444; }
.font-bold { font-weight: 700; }
.text-3xl { font-size: 1.875rem; line-height: 2.25rem; }
.text-2xl { font-size: 1.5rem; line-height: 2rem; }
.text-lg { font-size: 1.125rem; }
.text-base { font-size: 1rem; }
.text-sm { font-size: 0.875rem; }
.text-xs { font-size: 0.75rem; }
.p-4 { padding: 1rem; }
.rounded-xl { border-radius: 0.75rem; }
.shadow-sm { box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); }

/* Avatar component styles wrapper */
.avatar {
  border-radius: 50%;
  overflow: hidden;
  background-color: #e5e7eb;
}

/* Icons replacement will be SVG images or simple text for now */
/* Icons replacement will be SVG images or simple text for now */
.ml-auto { margin-left: auto; }

/* --- Utility Classes (Tailwind-like) --- */

/* Sizing (based on 4rpx scale usually, but approximations here for direct px/rpx mapping) */
.w-full { width: 100%; }
.h-full { height: 100%; }
.w-4 { width: 16rpx; } 
.h-4 { height: 16rpx; }
.w-5 { width: 20rpx; }
.h-5 { height: 20rpx; }
.w-6 { width: 24rpx; }
.h-6 { height: 24rpx; }
.w-8 { width: 32rpx; }
.h-8 { height: 32rpx; }
.w-10 { width: 40rpx; }
.h-10 { height: 40rpx; }
.w-12 { width: 48rpx; }
.h-12 { height: 48rpx; }
.w-16 { width: 64rpx; }
.h-16 { height: 64rpx; }
.w-20 { width: 80rpx; }
.h-20 { height: 80rpx; }
.w-24 { width: 96rpx; }
.h-24 { height: 96rpx; }

/* Margins & Padding */
.m-4 { margin: 32rpx; }
.mt-4 { margin-top: 32rpx; }
.mt-5 { margin-top: 20rpx; } /* Custom visual spacing */
.mt-6 { margin-top: 24rpx; }
.mb-1 { margin-bottom: 4rpx; }
.mb-2 { margin-bottom: 8rpx; }
.mb-4 { margin-bottom: 16rpx; }
.mb-6 { margin-bottom: 24rpx; }
.mr-2 { margin-right: 8rpx; }
.mr-3 { margin-right: 12rpx; }
.mr-4 { margin-right: 16rpx; }
.ml-2 { margin-left: 8rpx; }
.p-2 { padding: 8rpx; }
.p-3 { padding: 12rpx; }
.p-4 { padding: 32rpx; } /* Standard card padding */
.p-5 { padding: 40rpx; }
.px-3 { padding-left: 12rpx; padding-right: 12rpx; }
.px-4 { padding-left: 16rpx; padding-right: 16rpx; }
.px-6 { padding-left: 24rpx; padding-right: 24rpx; }
.py-1 { padding-top: 4rpx; padding-bottom: 4rpx; }
.py-1.5 { padding-top: 6rpx; padding-bottom: 6rpx; }

/* Flex & Grid */
.flex-1 { flex: 1; }
.flex-shrink-0 { flex-shrink: 0; }
.gap-2 { gap: 8rpx; }
.gap-3 { gap: 12rpx; }
.gap-4 { gap: 16rpx; }
.-space-x-2 > view, .-space-x-2 > image { margin-right: -8rpx; } /* Overlap hack simulation */

/* Borders & Radius */
.rounded-full { border-radius: 9999px; }
.rounded-lg { border-radius: 12rpx; }
.rounded-xl { border-radius: 20rpx; }
.rounded-2xl { border-radius: 24rpx; }
.border { border-width: 1rpx; }
.border-2 { border-width: 2rpx; }
.border-white { border-color: #ffffff; }
.border-gray-100 { border-color: #f3f4f6; }
.border-orange-100 { border-color: #ffedd5; }
.border-blue-100 { border-color: #dbeafe; }

/* Colors */
.bg-gray-50 { background-color: #f9fafb; }
.bg-gray-100 { background-color: #f3f4f6; }
.bg-gray-200 { background-color: #e5e7eb; }
.bg-blue-50 { background-color: #eff6ff; }
.bg-blue-600 { background-color: #2563eb; }
.text-gray-300 { color: #d1d5db; }
.text-gray-500 { color: #6b7280; }
.text-gray-600 { color: #4b5563; }
.text-orange-600 { color: #ea580c; }
.text-blue-600 { color: #2563eb; }
.text-green-600 { color: #16a34a; }

/* Text Size */
.text-xl { font-size: 36rpx; }
.text-4xl { font-size: 60rpx; }

/* Misc */
.relative { position: relative; }
.absolute { position: absolute; }
.fixed { position: fixed; }
.top-0 { top: 0; }
.right-0 { right: 0; }
.overflow-hidden { overflow: hidden; }
.shadow-sm { box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05); }
.truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

