.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px; /* rounded-lg */
  font-weight: 500;
  transition: all 0.2s;
  border: 1px solid transparent; /* One pixel border to prevent layout shift */
  box-sizing: border-box;
}

.btn:active {
  transform: scale(0.98);
}

.w-full {
  width: 100%;
  display: flex;
}

/* Variants */
.primary {
  background-color: #3b82f6; /* bg-blue-500 */
  color: #ffffff;
}
.primary:active {
  background-color: #2563eb; /* bg-blue-600 */
}

.secondary {
  background-color: #f3f4f6; /* bg-gray-100 */
  color: #111827; /* text-gray-900 */
}
.secondary:active {
  background-color: #e5e7eb; /* bg-gray-200 */
}

.danger {
  background-color: #ef4444; /* bg-red-500 */
  color: #ffffff;
}
.danger:active {
  background-color: #dc2626; /* bg-red-600 */
}

.ghost {
  background-color: transparent;
  color: #3b82f6; /* text-blue-500 */
}
.ghost:active {
  background-color: #eff6ff; /* bg-blue-50 */
}

/* Sizes */
.sm {
  height: 32px;
  padding: 0 12px;
  font-size: 12px;
}
.md {
  height: 40px;
  padding: 0 16px;
  font-size: 14px;
}
.lg {
  height: 48px;
  padding: 0 24px;
  font-size: 16px;
}
